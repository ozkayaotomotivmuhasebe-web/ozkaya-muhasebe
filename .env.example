# Environment Variables - Production için
# Bu dosyayı .gitignore'a ekleyin!

# Secret Key (uretmek icin: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-change-this-in-production

# Veritabani
DATABASE_URL=sqlite:///./muhasebe.db

# Uygulama ayarlari
APP_NAME=Muhasebe Sistemi
DEBUG=False

# Ngrok/Public URL ayarlari (opsiyonel)
PUBLIC_URL=

# CORS ayarlari (production'da belirli domainler)
ALLOWED_ORIGINS=*

# Session timeout (saniye)
SESSION_TIMEOUT=3600
